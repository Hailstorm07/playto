# Railway backend - Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=your-backend-name.up.railway.app,localhost

# Allow requests from your Vercel frontend
CORS_ALLOWED_ORIGINS=https://your-frontend-name.vercel.app,http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=^https://your-frontend-name-[a-z0-9]+-your-team-name\.vercel\.app$
CSRF_TRUSTED_ORIGINS=https://your-backend-name.up.railway.app,https://your-frontend-name.vercel.app,http://localhost:5173

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Database
# Railway automatically provides DATABASE_URL, no need to set manually
# But if needed: postgresql://user:password@host:port/dbname

# Vercel frontend variable
VITE_API_URL=https://your-backend-name.up.railway.app
